                            {{else}}
                            <span class="badge badge-warning">{{.issue_type}}</span>
                            {{end}}
                        </td>
                        <td>{{.suggestion}}</td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
            {{end}}
            {{end}}
            {{end}}

            <!-- 重复索引 -->
            {{if .performance.duplicate_indexes}}
            <h3>⚠️ 重复索引检测</h3>
            <p style="color: #e65100; margin-bottom: 15px;">以下表在相同列上存在多个索引,建议清理冗余索引</p>
            {{range .performance.duplicate_indexes}}
            {{if .indexes}}
            <h4>数据库: {{.name}}</h4>
            <table>
                <thead>
                    <tr>
                        <th>模式</th>
                        <th>表名</th>
                        <th>索引名</th>
                        <th>索引大小</th>
                        <th>扫描次数</th>
                        <th>索引定义</th>
                        <th>建议</th>
                    </tr>
                </thead>
                <tbody>
                    {{range .indexes}}
                    <tr style="background-color: #fff3e0;">
                        <td>{{.schemaname}}</td>
                        <td>{{.table_name}}</td>
                        <td>{{.index_name}}</td>
                        <td>{{.index_size}}</td>
                        <td>{{.index_scans}}</td>
                        <td style="max-width: 300px; word-wrap: break-word; font-size: 0.85em;">{{.index_definition}}</td>
                        <td>{{.suggestion}}</td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
            {{end}}
            {{end}}
            {{end}}
        </div>
        {{end}}

        <div class="footer">
            <p>由 DB Inspector 自动生成 | {{.generated_at}}</p>
        </div>
    </div>
</body>
</html>